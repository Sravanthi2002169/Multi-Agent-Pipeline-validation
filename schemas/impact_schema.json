{
  "type": "object",
  "required": [
    "schema_version",
    "pipeline_run_id",
    "stage",
    "stage_status",
    "impact_results",
    "files_analyzed",
    "files_with_impact"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "pipeline_run_id": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": [
        "impact_analysis"
      ]
    },
    "stage_status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "PARTIAL",
        "FAILURE"
      ]
    },
    "impact_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "file_path",
          "change_id",
          "severity",
          "reason",
          "recommended_action"
        ],
        "properties": {
          "file_path": {
            "type": "string"
          },
          "change_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 20
          },
          "affected_code_block": {
            "type": "string"
          },
          "recommended_action": {
            "type": "string",
            "enum": [
              "REMEDIATE",
              "REVIEW",
              "NO_ACTION"
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "severity": {
                  "const": "HIGH"
                }
              }
            },
            "then": {
              "required": [
                "affected_code_block"
              ]
            }
          }
        ]
      }
    },
    "files_analyzed": {
      "type": "integer"
    },
    "files_with_impact": {
      "type": "integer",
      "minimum": 0
    }
  }
}