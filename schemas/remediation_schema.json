{
  "type": "object",
  "required": [
    "schema_version",
    "pipeline_run_id",
    "stage",
    "stage_status",
    "timestamp",
    "remediated_files",
    "files_remediated",
    "files_skipped"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "pipeline_run_id": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": ["remediation"]
    },
    "stage_status": {
      "type": "string",
      "enum": ["SUCCESS", "PARTIAL", "FAILURE"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "remediated_files": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "original_path",
          "remediated_path",
          "rollback_path",
          "changes_applied",
          "change_id"
        ],
        "properties": {
          "original_path": {
            "type": "string"
          },
          "remediated_path": {
            "type": "string"
          },
          "rollback_path": {
            "type": "string"
          },
          "changes_applied": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "change_id": {
            "type": "string"
          }
        }
      }
    },
    "files_remediated": {
      "type": "integer",
      "minimum": 0
    },
    "files_skipped": {
      "type": "integer",
      "minimum": 0
    },
    "skip_reasons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file_path", "reason"],
        "properties": {
          "file_path": { "type": "string" },
          "reason": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "errors": {
    "type": "array",
      "items": { "type": "string" }
    }
  }
}