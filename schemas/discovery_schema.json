{
  "type": "object",
  "required": [
    "schema_version",
    "pipeline_run_id",
    "release",
    "stage",
    "stage_status",
    "timestamp",
    "summary",
    "impacted_files"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "pipeline_run_id": {
      "type": "string"
    },
    "release": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": ["discovery"]
    },
    "stage_status": {
      "type": "string",
      "enum": ["SUCCESS", "FAILURE"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "required": [
        "total_changes",
        "total_files_scanned",
        "total_files_impacted"
      ],
      "properties": {
        "total_changes": {
          "type": "integer",
          "minimum": 0
        },
        "total_files_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "total_files_impacted": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "impacted_files": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "file_path",
          "change_ids",
          "matched_patterns",
          "line_numbers"
        ],
        "properties": {
          "file_path": {
            "type": "string",
            "pattern": ".*\\.sql$"
          },
          "change_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "matched_patterns": {
            "type": "array",
            "items": { "type": "string" }
          },
          "line_numbers": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}